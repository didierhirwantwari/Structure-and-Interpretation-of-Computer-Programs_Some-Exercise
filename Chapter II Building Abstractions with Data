;prior necessary code
(define (gcd a b)
  (if (= b 0)
      a
      (gcd b (remainder a b ))))

;Having learned about making pairs we can now construct or rathers
;define how to make rational pairs by using
;cons, car, and cdr

;(define (make-rat n d) (cons n d)) ;old definition of make-rat

(define (make-rat n d)
  (let ((g (gcd n d )))
    (cons (/ n g) (/ d g))))



(define (numer x) (car x))
(define (denom x) (cdr x))




;There are rules that are defined for the arithmetic of rational numbers
;We define or provide them below

(define (add-rat x y)
  (make-rat (+ (* (numer x ) (denom y))
               (* (numer y) (denom x)))
            (* (denom x) (denom y))))

(define (sub-rat x y)
  (make-rat (- (* (numer x ) (denom y))
               (* (numer y) (denom x)))
            (* (denom x) (denom y))))


(define (mult-rat x y)
  (make-rat (* (numer x ) (numer y))
            (* (denom y) (denom x))))



(define (div-rat x y)
  (make-rat (* (numer x ) (denom y))
            (* (denom y) (denom x))))


(define (equal-rat? x y)
  (= (* (numer x ) (denom y))
     (* (numer y) (denom x))))




;Here we define how to print the rational number like we are
;used to see it mathematically

(define (print-rat x)
  (newline)
  (display ( numer x))
  (display "/")
  (display (denom x)))
 


;lets test this out
(define one-half (make-rat 1 2))
(print-rat one-half)

